# Ascendra deploy config. Copy to deploy/.env and fill in.
# Values that carry over from the current Railway backend are marked (from Railway).

# ---- Core ----
PUBLIC_URL=https://www.ascendrabio.com      # public origin; http://localhost:8080 for local test
HTTP_PORT=8080                              # nginx host port (80 on the server)
RUN_SEED=false                              # true only for a fresh empty DB; false when restoring a dump

# ---- Database (self-hosted Postgres in-stack) ----
POSTGRES_USER=ascendra
POSTGRES_PASSWORD=CHANGE_ME_strong
POSTGRES_DB=peptides_db

# ---- Object storage (self-hosted MinIO, S3-compatible) ----
MINIO_ROOT_USER=ascendra
MINIO_ROOT_PASSWORD=CHANGE_ME_strong
S3_BUCKET_NAME=ascendra-media

# ---- Auth ----
JWT_SECRET=CHANGE_ME_long_random
JWT_EXPIRE=7d

# ---- Email (from Railway) ----
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_SECURE=

# ---- Payments: Authorize.Net (from Railway) ----
ANET_API_LOGIN_ID=
ANET_TRANSACTION_KEY=
ANET_CLIENT_KEY=
ANET_ENV=production

# ---- ShipStation (from Railway) ----
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
SHIPSTATION_JWKS_URL=
SHIPSTATION_VALIDATE_ADDRESS=
SHIPSTATION_ALLOW_MOCK_FALLBACK=
SHIPSTATION_MAX_RETRIES=
SHIPSTATION_BACKOFF_MS=
SHIPSTATION_WEBHOOK_REPLAY_MS=

# ---- Twilio / SMS (from Railway) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ---- Store + shipping origin config (from Railway) ----
ADMIN_EMAIL=
SHIPPING_MANAGER_EMAIL=
SUPPLIER_EMAIL_POLL_CRON=
ZELLE_POLL_CRON=
STORE_NAME=
STORE_EMAIL=
STORE_PHONE=
STORE_ADDRESS=
STORE_WEBSITE=
SHIP_FROM_NAME=
SHIP_FROM_COMPANY=
SHIP_FROM_STREET=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_POSTAL=
SHIP_FROM_COUNTRY=
SHIP_FROM_PHONE=
SHIP_PKG_LENGTH_IN=
SHIP_PKG_WIDTH_IN=
SHIP_PKG_HEIGHT_IN=

# ---- Logging ----
LOG_LEVEL=info
DEBUG=
